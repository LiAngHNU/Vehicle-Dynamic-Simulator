  <P Name="chartFileNumber">23</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">ComputeLonCMDManual</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">242</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Throttle, Brake] = ComputeLonCMDManual(Trigger_Input)
    if Trigger_Input &lt; 0
        Throttle = -0.5*Trigger_Input;
        Brake = 0;
    else if Trigger_Input == 0
        Throttle = 0;
        Brake = 0;
    else
        Throttle = 0;
        Brake = 10*Trigger_Input;
    end
end</P>
      </eml>
    </state>
    <data SSID="4" name="Trigger_Input">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
