  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">64</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Whl_Kappa, Whl_Alpha] = ...
    Compute_Tyre_Kinematics(Delta_SW_Ref, Veh_Vx_Ref, Veh_Vy_Ref, Veh_AVz_Ref, Whl_AVy_Ref)
% Vehicle Parameters
     L  = [+1.265; +1.265; -1.895; -1.895];
     W  = [+0.802; -0.802; +0.802; -0.802];    
         
     R_whl = 0.368;
% Calculate Tyre Kinematic
    Whl_Vx = zeros(4,1);
    Whl_Vy = zeros(4,1);
     v_whl = zeros(4,1);

    Whl_Kappa = zeros(4,1);
    Whl_Alpha = zeros(4,1);

    for i = 1:1:4
        Whl_Vx(i,1) = + Veh_Vx_Ref - W(i,1)*Veh_AVz_Ref;
        Whl_Vy(i,1) = + Veh_Vy_Ref + L(i,1)*Veh_AVz_Ref;
         v_whl(i,1) = cos(Delta_SW_Ref(i,1))*sqrt(Whl_Vx(i,1)^2 + Whl_Vy(i,1)^2);

        Whl_Kappa(i,1) = (Whl_AVy_Ref(i,1)*R_whl - v_whl(i,1))/v_whl(i,1); 
        Whl_Alpha(i,1) = atan(Whl_Vy(i,1)/Whl_Vx(i,1)) - Delta_SW_Ref(i,1);
    end
end</P>
      </eml>
    </state>
