<?xml version="1.0" encoding="utf-8"?>
<chart id="101">
  <P Name="name">Estimation_Module/Tyre_Info_Estimation/Whl_Cy_Estimation/Whl_Cy_Estimation</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">101</P>
  <P Name="ssIdHighWaterMark">23</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">9</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Estimate_Whl_Cy</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">101</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Whl_Cyf_Est,Whl_Cyr_Est] = ...
    Estimate_Whl_Cy(Whl_Delta_Ref, Whl_Alpha_Ref, Veh_Vx_Ref, Veh_Vy_Ref, Veh_AVz_Ref, Veh_Ay_Ref, Veh_AAz_Ref)
% Vehicle Parameters
    a = 1.46;
    b = 2.675;
    m = 9069.2;
    i = 35428.5;

% Pre Processing
    Delta_f = 0.5*(Whl_Delta_Ref(1,1) + Whl_Delta_Ref(2,1));
    Alpha_f = 0.5*(Whl_Alpha_Ref(1,1) + Whl_Alpha_Ref(2,1));
    Alpha_r = 0.5*(Whl_Alpha_Ref(3,1) + Whl_Alpha_Ref(4,1));

% Whl_Cy Estimation
    Whl_Cyf_Est = 0.5*((b*m*Veh_Ay_Ref + b*m*Veh_Vx_Ref*Veh_AVz_Ref + i*Veh_AAz_Ref)/(a + b))/...
                  ((- Veh_Vy_Ref - a*Veh_AVz_Ref + Delta_f*Veh_Vx_Ref)/Veh_Vx_Ref);
    Whl_Cyr_Est = 0.5*((a*m*Veh_Ay_Ref + a*m*Veh_Vx_Ref*Veh_AVz_Ref - i*Veh_AAz_Ref)/(a + b))/...
                  ((- Veh_Vy_Ref + b*Veh_AVz_Ref)/Veh_Vx_Ref);
    if abs(Alpha_f) &lt; 0.005
        Whl_Cyf_Est = 0;
    else if abs(Whl_Cyf_Est) &gt; 500000
        Whl_Cyf_Est = 500000;
        end
    end

    if abs(Alpha_r) &lt; 0.005
        Whl_Cyr_Est = 0;
    else if abs(Whl_Cyr_Est) &gt; 500000
        Whl_Cyr_Est = 500000;
        end
    end
end</P>
      </eml>
    </state>
    <data SSID="21" name="Whl_Delta_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="23" name="Whl_Alpha_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="Whl_Cyf_Est">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="Veh_Vx_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
