    <P Name="name">Stanley_K_Interpolation</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">236</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function K_feed  = Stanley_K_Interpolation(Veh_Vx_Ref)
    K_table = load(&quot;Controllers\Lateral_Controller\Stanley_Controller\Conf\Stanley_K_table.mat&quot;);
    K_table = K_table.Stanley_K_Table;
    K_feed  = interp1(K_table(:,2), K_table(:,3), Veh_Vx_Ref, &apos;linear&apos;, &apos;extrap&apos;);
end</P>
      </eml>
    </state>
