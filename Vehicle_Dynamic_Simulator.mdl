      <P Name="subviewer">50</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [K_feed, K_lag, K_delay, K_prev] = OPC_K_Interpolation(Veh_Vx_Ref)
    K_table = load(&quot;Controllers\Lateral_Controller\Optimal_Preview_Controller\Conf\optimal_preview_K_table.mat&quot;);
    K_table = K_table.OPC_K_Table;
    
    K_total = zeros(1,226);

    for i=1:1:226
        K_total(1,i) = interp1(K_table(:,2), K_table(:,i+2), Veh_Vx_Ref, &apos;linear&apos;, &apos;extrap&apos;);
    end
    
    K_feed = K_total(1,1:4);
    K_lag  = K_total(1,5);
    K_delay= K_total(6:25);
    K_prev = K_total(26:226);
end</P>
      </eml>
    </state>
