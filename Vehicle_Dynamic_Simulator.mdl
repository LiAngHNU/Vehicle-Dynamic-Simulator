      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function K_feed_front = LQR_K_Interpolation(Veh_Vx_Ref)
    K_table_front = load(&quot;Models\Vehicles\C_3A_Cab_Over_6x4\Conf\LQR\LCLQR_K_table_front.mat&quot;);
    gains_matrix_front = K_table_front.gains_matrix_front;
    K_feed_front = zeros(1,5);

    for i=1:1:5
        K_feed_front(1,i) = interp1(gains_matrix_front(:,2), gains_matrix_front(:,i+2), Veh_Vx_Ref, &apos;linear&apos;, &apos;extrap&apos;);
    end
end</P>
      </eml>
