  <Block BlockType="SubSystem" Name="Localization_Module" SID="780">
    <P Name="Ports">[1, 1]</P>
    <P Name="Position">[315, 356, 405, 454]</P>
    <P Name="ZOrder">1596</P>
    <P Name="RequestExecContextInheritance">off</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Display RunInitForIconRedraw="off">addpath(&apos;Pictures&apos;);
image(&apos;Road.png&apos;); </Display>
      <Initialization>% Add Search Path
addpath(&apos;Roads&apos;);

% Test Road Selector
switch RoadFlag
    case 1      % Step Curvature: Kappa = 0.01
        Centerline = load(&apos;Step_Kappa_0.01.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;
    case 2      % Step Curvature: Kappa = 0.02
        Centerline = load(&apos;Step_Kappa_0.02.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;  
%     case 3      % Step Curvature: Kappa = 0.05
%         Centerline = load(&apos;Step_Kappa_0.05.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
%     case 4      % Ramp Curvature: dKappa = 0.01
%         Centerline = load(&apos;Ramp_dKappa_0.01.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
    case 5      % Road: uTurn
        Centerline = load(&apos;uTurn.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;
    case 6      % Road: Highway
        Centerline = load(&apos;Highway.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;
    case 7      % Road: Course2D
        Centerline = load(&apos;Course2D.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;
    case 8      % Road: Course3D
        Centerline = load(&apos;Course3D.mat&apos;);
        Index      = Centerline.Road.Index
        Station    = Centerline.Road.S;
        X_Global   = Centerline.Road.X;
        Y_Global   = Centerline.Road.Y;
        Theta      = Centerline.Road.Theta;
        Kappa      = Centerline.Road.Kappa;
end</Initialization>
      <MaskParameter Name="RoadFlag" Type="popup">
        <Prompt>Select Test Road</Prompt>
        <Value>Road: Course 2D</Value>
        <TypeOptions>
          <Option>Step Curvature: Kappa = 0.01</Option>
          <Option>Step Curvature: Kappa = 0.02</Option>
          <Option>Step Curvature: Kappa = 0.05</Option>
          <Option>Ramp Curvature: dKappa = 0.01</Option>
          <Option>Road: uTurn</Option>
          <Option>Road: Highway</Option>
          <Option>Road: Course 2D</Option>
          <Option>Road: Course 3D</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="PrevFlag" Type="checkbox">
        <Prompt>Enable Preview</Prompt>
        <Value>on</Value>
      </MaskParameter>
      <MaskParameter Name="Prev_Window" Type="edit">
        <Prompt>Input Preview Window</Prompt>
        <Value>0</Value>
        <ConstraintName>Constraint_Prev_Window</ConstraintName>
      </MaskParameter>
      <DialogControl Type="Group" Name="DescGroupVar">
        <Prompt>%&lt;MaskType&gt;</Prompt>
        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
      </DialogControl>
      <DialogControl Type="Group" Name="ParameterGroupVar">
        <Prompt>Simulink:studio:ToolBarParametersMenu</Prompt>
        <DialogControl Type="Popup" Name="RoadFlag">
          <Prompt>Select Test Road</Prompt>
          <ControlOptions HorizontalStretch="off"/>
        </DialogControl>
        <DialogControl Type="CheckBox" Name="PrevFlag">
          <Prompt>Enable Preview</Prompt>
        </DialogControl>
        <DialogControl Type="Edit" Name="Prev_Window">
          <Prompt>Input Preview Window</Prompt>
          <ControlOptions Row="current" HorizontalStretch="off"/>
        </DialogControl>
      </DialogControl>
      <ParameterConstraints Name="Constraint_Prev_Window">
        <ParameterConstraintRule>
          <DataType>double</DataType>
          <StringList PropName="Dimension">
            <String>scalar</String>
          </StringList>
          <StringList PropName="Complexity">
            <String>real</String>
          </StringList>
          <StringList PropName="Sign">
            <String>positive</String>
            <String>zero</String>
          </StringList>
          <StringList PropName="Finiteness">
            <String>finite</String>
          </StringList>
          <Minimum>0</Minimum>
          <Maximum>20</Maximum>
          <CustomConstraint/>
          <CustomErrorMessage/>
        </ParameterConstraintRule>
      </ParameterConstraints>
    </Mask>
    <System Ref="system_780"/>
  </Block>
