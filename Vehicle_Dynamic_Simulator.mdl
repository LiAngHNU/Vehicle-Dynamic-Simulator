  <P Name="chartFileNumber">3</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">ComputePathSPrev</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">45</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function Path_S_Prev = ComputePathSPrev(Path_S_Ref, ts,Veh_Vx_Ref)
    Path_S_Prev = zeros(201, 1);

    for i = 1:1:201
        Path_S_Prev(i, 1) = Path_S_Ref + (i-1)*ts*Veh_Vx_Ref;
    end
end</P>
      </eml>
    </state>
    <data SSID="6" name="Path_S_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
