  <Block BlockType="SubSystem" Name="Localization_Module" SID="780">
    <P Name="Ports">[1, 1, 0, 1]</P>
    <P Name="Position">[140, 401, 230, 499]</P>
    <P Name="ZOrder">1596</P>
    <P Name="BackgroundColor">[0.952941, 0.956863, 0.945098]</P>
    <P Name="RequestExecContextInheritance">off</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Display RunInitForIconRedraw="off">addpath(&apos;Pictures&apos;);
image(&apos;Localization_Module.png&apos;); </Display>
      <Initialization>% Add Search Path
addpath(&apos;Scenarios&apos;);
addpath(&apos;Scenarios\Scenario_Test_Flat_Pad&apos;);
addpath(&apos;Scenarios\Scenario_MCity&apos;);
addpath(&apos;Scenarios\Scenario_Highway&apos;);
addpath(&apos;Scenarios\Scenario_Border_City&apos;)

% Test Road Selector
switch FLAGS_choose_path
    case 1
        load(&apos;Path_Curvature_Step_Response_8m_Radius.mat&apos;);
    case 2
        load(&apos;Path_Curvature_Step_Response_10m_Radius.mat&apos;);
    case 3
        load(&apos;Path_Curvature_Step_Response_16m_Radius.mat&apos;);
    case 4
        load(&apos;Path_Curvature_Step_Response_20m_Radius.mat&apos;);
    case 5
        load(&apos;Path_Curvature_Step_Response_40m_Radius.mat&apos;);
    case 6
        load(&apos;Path_Curvature_Step_Response_50m_Radius.mat&apos;);
    case 7
        load(&apos;Path_Curvature_Step_Response_80m_Radius.mat&apos;);
    case 8
        load(&apos;Path_Curvature_Step_Response_100m_Radius.mat&apos;);
    case 9
        load(&apos;Path_MCity_Outside_Loop.mat&apos;);
    case 10
        load(&apos;Path_MCity_Highway_Loop.mat&apos;);
    case 11
        load(&apos;Path_MCity_Inside_Loop.mat&apos;);
    case 12
        load(&apos;Path_Highway_Clockwise.mat&apos;);
    case 13
        load(&apos;Path_Border_City_Offroad.mat&apos;);

%     case 2
%         load(&apos;MCity_M_Loop.mat&apos;)
% 
%     case 3      % Road: Course2D
%         load(&apos;Path_HandlingCourse.mat&apos;);
% 
%     case 8      % Road: Course3D
%         Path = load(&apos;Course3D.mat&apos;);
%         Index      = Path.Road.Index
%         Station    = Path.Road.S;
%         X_Global   = Path.Road.X;
%         Y_Global   = Path.Road.Y;
%         Theta      = Path.Road.Theta;
%         Kappa      = Path.Road.Kappa; 
        
%     case 1      % Step Curvature: Kappa = 0.01
%         Centerline = load(&apos;Step_Kappa_0.01.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
%     case 2      % Step Curvature: Kappa = 0.02
%         Centerline = load(&apos;Step_Kappa_0.02.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;  
%     case 3      % Step Curvature: Kappa = 0.05
%         Centerline = load(&apos;Step_Kappa_0.05.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
%     case 4      % Ramp Curvature: dKappa = 0.01
%         Centerline = load(&apos;Ramp_dKappa_0.01.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
%     case 5      % Road: uTurn
%         Centerline = load(&apos;uTurn.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
%     case 6      % Road: Highway
%         Centerline = load(&apos;Highway.mat&apos;);
%         Index      = Centerline.Road.Index
%         Station    = Centerline.Road.S;
%         X_Global   = Centerline.Road.X;
%         Y_Global   = Centerline.Road.Y;
%         Theta      = Centerline.Road.Theta;
%         Kappa      = Centerline.Road.Kappa;
end</Initialization>
      <MaskParameter Name="FLAGS_choose_path" Type="popup">
        <Prompt>Select Path</Prompt>
        <Value>MCity: Inside Loop</Value>
        <TypeOptions>
          <Option>Test: Step Curvature Response: 8m Radius</Option>
          <Option>Test: Step Curvature Response: 10m Radius</Option>
          <Option>Test: Step Curvature Response: 16m Radius</Option>
          <Option>Test: Step Curvature Response: 20m Radius</Option>
          <Option>Test: Step Curvature Response: 40m Radius</Option>
          <Option>Test: Step Curvature Response: 50m Radius</Option>
          <Option>Test: Step Curvature Response: 80m Radius</Option>
          <Option>Test: Step Curvature Response: 100m Radius</Option>
          <Option>MCity: Outside Loop</Option>
          <Option>MCity: Highway Loop</Option>
          <Option>MCity: Inside Loop</Option>
          <Option>Highway: Clockwise</Option>
          <Option>Track: Handling Course Racing Line</Option>
          <Option>BorderCity: Offroad</Option>
        </TypeOptions>
      </MaskParameter>
      <MaskParameter Name="FLAGS_enable_preview" Type="checkbox">
        <Prompt>Enable Preview</Prompt>
        <Value>on</Value>
      </MaskParameter>
      <MaskParameter Name="FLAGS_preview_window" Type="edit">
        <Prompt>Input Preview Window</Prompt>
        <Value>0</Value>
        <ConstraintName>Constraint_Prev_Window</ConstraintName>
      </MaskParameter>
      <DialogControl Type="Group" Name="DescGroupVar">
        <Prompt>%&lt;MaskType&gt;</Prompt>
        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
      </DialogControl>
      <DialogControl Type="Group" Name="ParameterGroupVar">
        <Prompt>Simulink:studio:ToolBarParametersMenu</Prompt>
        <DialogControl Type="Popup" Name="FLAGS_choose_path">
          <Prompt>Select Path</Prompt>
          <ControlOptions HorizontalStretch="off"/>
        </DialogControl>
        <DialogControl Type="CheckBox" Name="FLAGS_enable_preview">
          <Prompt>Enable Preview</Prompt>
        </DialogControl>
