image(&apos;Vehicle_Module.png&apos;); </Display>
      <Initialization>% Add Search Path
addpath(&apos;Models&apos;)
addpath(&apos;Models\Vehicles&apos;);

% Test Vehicle Selector
switch VehicleFlag
%     case 1
%       load(&apos;Truck_106_Daimler_Auman.mat&apos;).Vehicle;
    case 2
        addpath(&apos;Models\Vehicles\C_3A_Cab_Over_6x4&apos;);
        load(&apos;C_3A_Cab_Over_6x4_Calib.mat&apos;);
%     case 3
%     case 4
end</Initialization>
      <MaskParameter Name="VehicleFlag" Type="popup">
        <Prompt>Select Test Vehicle</Prompt>
        <Value>Commercial: 3A Cab-Over 6x4</Value>
        <TypeOptions>
          <Option>Passenger: F-Class Sedan</Option>
          <Option>Commercial: 3A Cab-Over 6x4</Option>
        </TypeOptions>
      </MaskParameter>
