<?xml version="1.0" encoding="utf-8"?>
<chart id="115">
  <P Name="name">Control_Module/Lat_Controller/Stanley_Controller/MATLAB Function1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">115</P>
  <P Name="ssIdHighWaterMark">12</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">10</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Compute_Stanley</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">115</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function Lat_CMD = Compute_Stanley(error_y, error_phi, vx_veh_ref, vy_veh_ref, avz_veh_ref, delta_sw, gain)
    vf = vx_veh_ref + 0.04*(vy_veh_ref + 1.265*avz_veh_ref)*delta_sw;
    Lat_CMD = error_phi + atan((gain*error_y)/(vf + 0.01));
end</P>
      </eml>
    </state>
    <data SSID="5" name="Lat_CMD">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
