      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function Path_S_Prev = ComputePathSPrev(Path_S_Ref, ts,Veh_Vx_Ref)
    Path_S_Prev = zeros(201, 1);

    for i = 1:1:201
        Path_S_Prev(i, 1) = Path_S_Ref + (i-1)*ts*Veh_Vx_Ref;
    end
end</P>
