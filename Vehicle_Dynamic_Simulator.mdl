<chart id="54">
  <P Name="name">Control_Module/Lat_Controller/Offline_OPC_Controller/MATLAB Function2</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">54</P>
  <P Name="ssIdHighWaterMark">16</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">4</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">OPC_K_Interpolation</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">54</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [K_feed, K_lag, K_delay, K_prev] = OPC_K_Interpolation(Veh_Vx_Ref)
    K_table = load(&quot;Controllers\Lateral_Controller\Optimal_Preview_Controller\Conf\optimal_preview_K_table.mat&quot;);
    K_table = K_table.OPC_K_Table;
    
    K_total = zeros(1,226);

    for i=1:1:226
        K_total(1,i) = interp1(K_table(:,2), K_table(:,i+2), Veh_Vx_Ref, &apos;linear&apos;, &apos;extrap&apos;);
    end
    
    K_feed = K_total(1,1:4);
    K_lag  = K_total(1,5);
    K_delay= K_total(6:25);
    K_prev = K_total(26:226);
end</P>
      </eml>
    </state>
    <data SSID="7" name="K_feed">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
