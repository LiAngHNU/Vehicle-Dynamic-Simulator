<chart id="148">
  <P Name="name">Control_Module/Lat_Controller/Offline_LQR_Controller/ILCLQR_Controller/ILCLQR_K_Interpolation</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">148</P>
  <P Name="ssIdHighWaterMark">18</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">13</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">ILCLQR_K_Interpolation</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">148</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function K_feed_front = ILCLQR_K_Interpolation(Veh_Vx_Ref)
    K_table_front = load(&quot;Models\Vehicles\C_3A_Cab_Over_6x4\Conf\LQR\ILCLQR_K_table_front.mat&quot;);
    gains_matrix_front = K_table_front.gains_matrix_front;
    K_feed_front = zeros(1,6);

    for i=1:1:6
        K_feed_front(1,i) = interp1(gains_matrix_front(:,2), gains_matrix_front(:,i+2), Veh_Vx_Ref, &apos;linear&apos;, &apos;extrap&apos;);
    end
end</P>
      </eml>
    </state>
    <data SSID="7" name="K_feed_front">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
