<?xml version="1.0" encoding="utf-8"?>
<chart id="64">
  <P Name="name">Control_Module/Vehicle_Model/7DOF_Model/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">64</P>
  <P Name="ssIdHighWaterMark">15</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">5</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Vehicle_Model</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">64</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [kappa_whl, alpha_whl, ax_veh, ay_veh, aaz_veh] = ...
    Vehicle_Model(delta_whl, vx_veh, vy_veh, avz_veh, avy_whl)
% Vehicle Parameters
     W  = [+0.775; -0.775; +0.825; -0.825];    
     L  = [+0.970; +0.970; -1.810; -1.810];
     Kx = [+45000; +45000; +45000; +45000];      
     Ky = [-50000; -50000; -50000; -50000];    
     M  = 1521;                  
     Iz = 1816;          
     R_whl = 0.329;
% Calculate Tyre Kinematic
    vx_whl = zeros(4,1);
    vy_whl = zeros(4,1);
     v_whl = zeros(4,1);

    kappa_whl = zeros(4,1);
    alpha_whl = zeros(4,1);

    for i = 1:1:4
        vx_whl(i,1) = vx_veh - W(i,1)*avz_veh;
        vy_whl(i,1) = vy_veh + L(i,1)*avz_veh;
         v_whl(i,1) = cos(delta_whl(i,1))*sqrt(vx_whl(i,1)^2 + vy_whl(i,1)^2);

        kappa_whl(i,1) = (avy_whl(i,1)*R_whl - v_whl(i,1))/v_whl(i,1); 
        alpha_whl(i,1) = atan(vy_whl(i,1)/vx_whl(i,1)) - delta_whl(i,1);
    end

% Calculate State   
     ax_veh =  vy_veh*avz_veh;
     ay_veh = -vx_veh*avz_veh;
    aaz_veh = 0;
    for j = 1:1:4
        ax_veh = ax_veh + ...
            (1/M)*(Kx(i,1)*kappa_whl(i,1)*cos(delta_whl(i,1)) - ...
                   Ky(i,1)*alpha_whl(i,1)*sin(delta_whl(i,1)));
        ay_veh = ay_veh + ...
            (1/M)*(Kx(i,1)*kappa_whl(i,1)*sin(delta_whl(i,1)) + ...
                   Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));
        aaz_veh = aaz_veh + ...
            (1/Iz)*(-W(i,1))*...
            (Kx(i,1)*kappa_whl(i,1)*cos(delta_whl(i,1)) - ...
             Ky(i,1)*alpha_whl(i,1)*sin(delta_whl(i,1))) + ...
            (1/Iz)*(L(i,1))*...
            (Kx(i,1)*kappa_whl(i,1)*sin(delta_whl(i,1)) - ...
             Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));
    end
end</P>
      </eml>
    </state>
    <data SSID="14" name="delta_whl">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="kappa_whl">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="vx_veh">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="vy_veh">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="avz_veh">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
