<chart id="25">
  <P Name="name">Localization_Module/Frenet_Based_Method/Frenet_Based_Error_Calculation/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">25</P>
  <P Name="visible">1</P>
  <subviewS/>
  <P Name="ssIdHighWaterMark">15</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">2</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">Error_Calculate</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">25</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Veh_ErrY_Est, Veh_ErrVy_Est, Veh_ErrYz_Est, Veh_ErrAVz_Est] = ...
    Error_Calculate(Path_Theta_Est, ...
                    Path_Kappa_Est, ...
                    Path_L_Ref,     ...
                    Veh_Yz_Ref,     ...                  
                    Veh_Vx_Ref,     ...
                    Veh_Vy_Ref,     ...
                    Veh_AVz_Ref)
    Veh_ErrY_Est   = Path_L_Ref;
    Veh_ErrYz_Est  = Veh_Yz_Ref - Path_Theta_Est;
    Veh_ErrVy_Est  = Veh_Vy_Ref + Veh_Vx_Ref*Veh_ErrYz_Est;
    Veh_ErrAVz_Est = Veh_AVz_Ref - Veh_Vx_Ref*Path_Kappa_Est;
end</P>
      </eml>
    </state>
    <data SSID="10" name="Path_Theta_Est">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
