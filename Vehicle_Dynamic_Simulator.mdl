<chart id="231">
  <P Name="name">Estimation_Module/Axle_Info_Estimation/Axl_Fy_Estimation/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">231</P>
  <P Name="ssIdHighWaterMark">9</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">22</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">ComputeAxleLateralForce</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">231</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Axl_1_Fy_Est, Axl_1_Fy_Ref] = ComputeAxleLateralForce(Whl_Delta_Ref, ... 
                                                            Whl_Fx_Ref, ...
                                                            Whl_Fy_Ref, ...
                                                            Axl_Fy_Ref)
    Axl_1_Fy_Est = ...
     -Whl_Fx_Ref(1,1)*sin(Whl_Delta_Ref(1,1)) - ...
      Whl_Fx_Ref(2,1)*sin(Whl_Delta_Ref(2,1)) + ...
      Whl_Fy_Ref(1,1)*cos(Whl_Delta_Ref(1,1)) + ...
      Whl_Fy_Ref(2,1)*cos(Whl_Delta_Ref(2,1));
    Axl_1_Fy_Ref = Axl_Fy_Ref(1,1);
end</P>
      </eml>
    </state>
    <data SSID="4" name="Whl_Delta_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
