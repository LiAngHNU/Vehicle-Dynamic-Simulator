<?xml version="1.0" encoding="utf-8"?>
<System>
  <P Name="Location">[-668, -871, 882, 7]</P>
  <P Name="SystemRect">[0.000000, 0.000000, 0.000000, 0.000000]</P>
  <P Name="SetExecutionDomain">off</P>
  <P Name="ExecutionDomainType">Deduce</P>
  <P Name="ReportName">simulink-default.rpt</P>
  <P Name="SIDHighWatermark">1415</P>
  <P Name="SimulinkSubDomain">Simulink</P>
  <Block BlockType="BusCreator" Name="Bus&#xA;Creator" SID="978">
    <P Name="Ports">[2, 1]</P>
    <P Name="Position">[455, 501, 460, 539]</P>
    <P Name="ZOrder">1615</P>
    <P Name="Inputs">2</P>
    <P Name="DisplayOption">bar</P>
    <P Name="InheritFromInputs">on</P>
  </Block>
  <Block BlockType="SubSystem" Name="CarSim_Module" SID="836">
    <P Name="Ports">[1, 1]</P>
    <P Name="Position">[140, 472, 230, 568]</P>
    <P Name="ZOrder">1609</P>
    <P Name="RequestExecContextInheritance">off</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Display>image(&apos;TruckSim.png&apos;); % 使用工具条上的 &quot;编辑图像&quot; 进行更改。</Display>
      <MaskParameter Name="LonFlag" Type="checkbox">
        <Prompt>use custom lon controller</Prompt>
        <Value>off</Value>
      </MaskParameter>
      <MaskParameter Name="LatFlag" Type="checkbox">
        <Prompt>use custom lat controller</Prompt>
        <Value>on</Value>
      </MaskParameter>
      <DialogControl Type="Group" Name="DescGroupVar">
        <Prompt>%&lt;MaskType&gt;</Prompt>
        <DialogControl Type="Text" Name="DescTextVar">
          <Prompt>%&lt;MaskDescription&gt;</Prompt>
        </DialogControl>
      </DialogControl>
      <DialogControl Type="Group" Name="ParameterGroupVar">
        <Prompt>Simulink:studio:ToolBarParametersMenu</Prompt>
        <DialogControl Type="CheckBox" Name="LonFlag">
          <Prompt>use custom lon controller</Prompt>
        </DialogControl>
        <DialogControl Type="CheckBox" Name="LatFlag">
          <Prompt>use custom lat controller</Prompt>
        </DialogControl>
      </DialogControl>
    </Mask>
    <System Ref="system_836"/>
  </Block>
  <Block BlockType="SubSystem" Name="Chassis_Module" SID="784">
    <P Name="Ports">[1, 1]</P>
    <P Name="Position">[315, 582, 405, 678]</P>
    <P Name="ZOrder">1597</P>
    <P Name="RequestExecContextInheritance">off</P>
    <P Name="ContentPreviewEnabled">on</P>
    <Mask>
      <Display RunInitForIconRedraw="off">addpath(&apos;Pictures&apos;);
image(&apos;Vehicle.png&apos;); </Display>
      <Initialization>% Add Search Path
addpath(&apos;Vehicles&apos;);

% Test Vehicle Selector
switch VehicleFlag
    case 1
        Vehicle         = load(&apos;Truck_106_Daimler_Auman.mat&apos;).Vehicle;
        TotalMass       = Vehicle.TotalMass;
        TotalInertia    = Vehicle.TotalInertia;
        TyreStiffness   = Vehicle.AxleStiffness;
        AxlePosition    = Vehicle.AxlePosition;
%     case 2
%     case 3
%     case 4
%         Vehicle         = load(&apos;Truck_106_Daimler_Auman.mat&apos;).Vehicle;
%         TotalMass       = Vehicle.TotalMass;
%         TotalInertia    = Vehicle.TotalInertia;
%         TyreStiffness   = Vehicle.AxleStiffness;
%         AxlePosition    = Vehicle.AxlePosition;
%         ...
end</Initialization>
      <MaskParameter Name="VehicleFlag" Type="popup">
        <Prompt>Select Test Vehicle</Prompt>
        <Value>Truck_106_Daimler_Auman</Value>
        <TypeOptions>
          <Option>Truck_106_Daimler_Auman</Option>
        </TypeOptions>
