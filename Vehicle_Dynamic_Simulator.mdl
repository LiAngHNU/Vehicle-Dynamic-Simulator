<?xml version="1.0" encoding="utf-8"?>
<chart id="128">
  <P Name="name">Control_Module/Lat_Controller/Offline_OPC_Controller/MATLAB Function1</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">128</P>
  <P Name="ssIdHighWaterMark">18</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">11</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">OPC_FeedForward</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">128</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function delta_ff   = OPC_FeedForward(Paht_Kappa_Ref, Veh_Vx_Ref, K_feed, delta_prev)
    MT = 2020; IZ = 4095; LF = 1.265; LR = 1.895; KF = -70000; KR = -70000;
    
    a23 = -2*(KF+KR)/MT;
    a43 = -2*(KF*LF-KR*LR)/IZ;	
	b21 = -2*KF/MT;

    b41 = -2*KF*LF/IZ;
	d21 = 2*(KF*LF-KR*LR)/MT - Veh_Vx_Ref*Veh_Vx_Ref;		
    d41 = 2*(KF*LF*LF+KR*LR*LR)/IZ;


    k1 = K_feed(1,1);
    k3 = K_feed(1,3);

    Paht_Kappa_Ref = Paht_Kappa_Ref(1,1);
    delta_ff = (((b21*delta_prev - d21*Paht_Kappa_Ref)*(a43 - b41*k3))/(a23*b41*k1 - a43*b21*k1) - ((b41*delta_prev - d41*Paht_Kappa_Ref)*(a23 - b21*k3))/(a23*b41*k1 - a43*b21*k1))/((b41*(a23 - b21*k3))/(a23*b41*k1 - a43*b21*k1) - (b21*(a43 - b41*k3))/(a23*b41*k1 - a43*b21*k1));
end</P>
      </eml>
    </state>
    <data SSID="7" name="delta_ff">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="15" name="Paht_Kappa_Ref">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="16" name="Veh_Vx_Ref">
