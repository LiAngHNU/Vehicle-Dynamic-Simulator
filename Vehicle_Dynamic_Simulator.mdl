        </DialogControl>
        <DialogControl Type="Popup" Name="ModelFlag">
          <Prompt>Model Type</Prompt>
          <ControlOptions Row="current" HorizontalStretch="off"/>
        </DialogControl>
      </DialogControl>
    </Mask>
    <System Ref="system_3040"/>
  </Block>
