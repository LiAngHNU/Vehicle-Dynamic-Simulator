  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">S_Prev_Calculate</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">46</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function s_prev = S_Prev_Calculate(vx, ts, s)
    s_prev = zeros(201, 1);

    for i = 1:1:201
        s_prev(i, 1) = s + (i-1)*ts*vx;
    end
end</P>
      </eml>
    </state>
