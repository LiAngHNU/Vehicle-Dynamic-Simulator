      RequestExecContextInheritance off
      ContentPreviewEnabled   on
      Object {
	$PropName		"MaskObject"
	$ObjectID		150
	$ClassName		"Simulink.Mask"
	Initialization		"% Add Search Path\naddpath('Roads');\n\n% Test Road Selector\nswitch RoadFlag\n    case 1      % Ste"
	"p Curvature: Kappa = 0.01\n        Centerline = load('Step_Kappa_0.01.mat');\n        Index      = Centerline.Road.In"
	"dex\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerlin"
	"e.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    case 2      "
	"% Step Curvature: Kappa = 0.02\n        Centerline = load('Step_Kappa_0.02.mat');\n        Index      = Centerline.Ro"
	"ad.Index\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Cent"
	"erline.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;  \n%     cas"
	"e 3      % Step Curvature: Kappa = 0.05\n%         Centerline = load('Step_Kappa_0.05.mat');\n%         Index      = "
	"Centerline.Road.Index\n%         Station    = Centerline.Road.S;\n%         X_Global   = Centerline.Road.X;\n%       "
	"  Y_Global   = Centerline.Road.Y;\n%         Theta      = Centerline.Road.Theta;\n%         Kappa      = Centerline.R"
	"oad.Kappa;\n%     case 4      % Ramp Curvature: dKappa = 0.01\n%         Centerline = load('Ramp_dKappa_0.01.mat');\n"
	"%         Index      = Centerline.Road.Index\n%         Station    = Centerline.Road.S;\n%         X_Global   = Cente"
	"rline.Road.X;\n%         Y_Global   = Centerline.Road.Y;\n%         Theta      = Centerline.Road.Theta;\n%         Ka"
	"ppa      = Centerline.Road.Kappa;\n    case 5      % Road: uTurn\n        Centerline = load('uTurn.mat');\n        In"
	"dex      = Centerline.Road.Index\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n "
	"       Y_Global   = Centerline.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline."
	"Road.Kappa;\n    case 6      % Road: Highway\n        Centerline = load('Highway.mat');\n        Index      = Centerl"
	"ine.Road.Index\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   "
	"= Centerline.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    c"
	"ase 7      % Road: Course2D\n        Centerline = load('Course2D.mat');\n        Index      = Centerline.Road.Index\n"
	"        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Roa"
	"d.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    case 8      % Roa"
	"d: Course3D\n        Centerline = load('Course3D.mat');\n        Index      = Centerline.Road.Index\n        Station "
	"   = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Road.Y;\n        Th"
	"eta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\nend"
	Display			"addpath('Pictures');\nimage('Road.png'); "
	RunInitForIconRedraw	"off"
	Array {
	  Type			  "Simulink.MaskParameter"
	  Dimension		  3
	  Object {
	    $ObjectID		    151
	    Type		    "popup"
	    Array {
	      Type		      "Cell"
	      Dimension		      8
	      Cell		      "Step Curvature: Kappa = 0.01"
	      Cell		      "Step Curvature: Kappa = 0.02"
	      Cell		      "Step Curvature: Kappa = 0.05"
	      Cell		      "Ramp Curvature: dKappa = 0.01"
	      Cell		      "Road: uTurn"
	      Cell		      "Road: Highway"
	      Cell		      "Road: Course 2D"
	      Cell		      "Road: Course 3D"
	      PropName		      "TypeOptions"
	    }
	    Name		    "RoadFlag"
	    Prompt		    "Select Test Road"
	    Value		    "Road: Course 3D"
	  }
	  Object {
	    $ObjectID		    152
	    Type		    "checkbox"
	    Name		    "PrevFlag"
	    Prompt		    "Enable Preview"
