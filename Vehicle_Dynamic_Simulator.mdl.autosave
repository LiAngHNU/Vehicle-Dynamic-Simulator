  state {
    id			    74
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    73
    treeNode		    [73 0 0 0]
    superState		    SUBCHART
    subviewer		    73
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function [ax_veh, ay_veh, aaz_veh] = ...\n    Vehicle_Model(kappa_whl, alpha_whl)\n% Vehicle Para"
      "meters\n     W  = [+0.775; -0.775; +0.825; -0.825];    \n     L  = [+0.970; +0.970; -1.810; -1.810];\n     Kx = "
      "[+45000; +45000; +45000; +45000];      \n     Ky = [-50000; -50000; -50000; -50000];    \n     M  = 1521;       "
      "           \n     Iz = 1816;          \n\n% Calculate State   \n     ax_veh =  vy_veh*avz_veh;\n     ay_veh = -v"
      "x_veh*avz_veh;\n    aaz_veh = 0;\n    for i = 1:1:4\n        ax_veh = ax_veh + ...\n            (1/M)*(Kx(i,1)*k"
      "appa_whl(i,1)*cos(delta_whl(i,1)) - ...\n                   Ky(i,1)*alpha_whl(i,1)*sin(delta_whl(i,1)));\n      "
      "  ay_veh = ay_veh + ...\n            (1/M)*(Kx(i,1)*kappa_whl(i,1)*sin(delta_whl(i,1)) + ...\n                  "
      " Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));\n        aaz_veh = aaz_veh + ...\n            (1/Iz)*(-W(i,1))*..."
      "\n            (Kx(i,1)*kappa_whl(i,1)*cos(delta_whl(i,1)) - ...\n             Ky(i,1)*alpha_whl(i,1)*sin(delta_w"
      "hl(i,1))) + ...\n            (1/Iz)*(L(i,1))*...\n            (Kx(i,1)*kappa_whl(i,1)*sin(delta_whl(i,1)) - ...\n"
      "             Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));\n    end\nend"
    }
  }
