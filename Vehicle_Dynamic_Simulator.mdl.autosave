	Block {
	  BlockType		  SubSystem
	  Name			  "Lon_Controller"
	  SID			  "890"
	  Ports			  [1, 1]
	  Position		  [195, 47, 285, 143]
	  ZOrder		  1600
	  Commented		  "on"
	  RequestExecContextInheritance	off
	  ContentPreviewEnabled	  on
	  Object {
	    $PropName		    "MaskObject"
	    $ObjectID		    134
	    $ClassName		    "Simulink.Mask"
	    Initialization	    "% Add Search Path\naddpath('Roads');\n\n% Test Road Selector\nswitch RoadFlag\n    case 1    "
	    "  % Step Curvature: Kappa = 0.01\n        Centerline = load('Step_Kappa_0.01.mat');\n        Index      = Centerl"
	    "ine.Road.Index\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Globa"
	    "l   = Centerline.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa"
	    ";\n    case 2      % Step Curvature: Kappa = 0.02\n        Centerline = load('Step_Kappa_0.02.mat');\n        Ind"
	    "ex      = Centerline.Road.Index\n        Station    = Centerline.Road.S;\n        X_Global   = Centerline.Road.X;"
	    "\n        Y_Global   = Centerline.Road.Y;\n        Theta      = Centerline.Road.Theta;\n        Kappa      = Cent"
	    "erline.Road.Kappa;  \n%     case 3      % Step Curvature: Kappa = 0.05\n%         Centerline = load('Step_Kappa_0"
	    ".05.mat');\n%         Index      = Centerline.Road.Index\n%         Station    = Centerline.Road.S;\n%         X_"
	    "Global   = Centerline.Road.X;\n%         Y_Global   = Centerline.Road.Y;\n%         Theta      = Centerline.Road."
	    "Theta;\n%         Kappa      = Centerline.Road.Kappa;\n%     case 4      % Ramp Curvature: dKappa = 0.01\n%      "
	    "   Centerline = load('Ramp_dKappa_0.01.mat');\n%         Index      = Centerline.Road.Index\n%         Station   "
	    " = Centerline.Road.S;\n%         X_Global   = Centerline.Road.X;\n%         Y_Global   = Centerline.Road.Y;\n%   "
	    "      Theta      = Centerline.Road.Theta;\n%         Kappa      = Centerline.Road.Kappa;\n    case 5      % Road:"
	    " uTurn\n        Centerline = load('uTurn.mat');\n        Index      = Centerline.Road.Index\n        Station    ="
	    " Centerline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Road.Y;\n        Th"
	    "eta      = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    case 6      % Road: Highway\n"
	    "        Centerline = load('Highway.mat');\n        Index      = Centerline.Road.Index\n        Station    = Cente"
	    "rline.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Road.Y;\n        Theta   "
	    "   = Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    case 7      % Road: Course2D\n     "
	    "   Centerline = load('Course2D.mat');\n        Index      = Centerline.Road.Index\n        Station    = Centerlin"
	    "e.Road.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Road.Y;\n        Theta      ="
	    " Centerline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\n    case 8      % Road: Course3D\n        C"
	    "enterline = load('Course3D.mat');\n        Index      = Centerline.Road.Index\n        Station    = Centerline.Ro"
	    "ad.S;\n        X_Global   = Centerline.Road.X;\n        Y_Global   = Centerline.Road.Y;\n        Theta      = Cen"
	    "terline.Road.Theta;\n        Kappa      = Centerline.Road.Kappa;\nend"
	    RunInitForIconRedraw    "off"
	    Array {
	      Type		      "Simulink.MaskParameter"
	      Dimension		      2
	      Object {
		$ObjectID		135
		Type			"popup"
		Array {
		  Type			  "Cell"
		  Dimension		  8
		  Cell			  "Step Curvature: Kappa = 0.01"
		  Cell			  "Step Curvature: Kappa = 0.02"
		  Cell			  "Step Curvature: Kappa = 0.05"
		  Cell			  "Ramp Curvature: dKappa = 0.01"
		  Cell			  "Road: uTurn"
		  Cell			  "Road: Highway"
		  Cell			  "Road: Course 2D"
		  Cell			  "Road: Course 3D"
		  PropName		  "TypeOptions"
		}
		Name			"RoadFlag"
		Prompt			"Select Test Road"
		Value			"Step Curvature: Kappa = 0.02"
	      }
