  chart {
    id			    46
    machine		    1
    name		    "Control_Module/Vehicle_Model/7DOF_Model/MATLAB Function"
    windowPosition	    [422 539.941 189 413]
    viewLimits		    [0 156.75 0 153.75]
    screen		    [1 1 3600 1200 1.180555555555556]
    treeNode		    [0 47 0 0]
    viewObj		    46
    ssIdHighWaterMark	    15
    decomposition	    CLUSTER_CHART
    type		    EML_CHART
    chartFileNumber	    5
    disableImplicitCasting  1
    eml {
      name		      "Vehicle_Model"
    }
    firstData		    48
    firstTransition	    59
    firstJunction	    58
  }
  state {
    id			    47
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    46
    treeNode		    [46 0 0 0]
    superState		    SUBCHART
    subviewer		    46
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function [kappa_whl, alpha_whl, ax_veh, ay_veh, aaz_veh] = ...\n    Vehicle_Model(delta_whl, vx_v"
      "eh, vy_veh, avz_veh, avy_whl)\n% Vehicle Parameters\n     W  = [+0.775; -0.775; +0.825; -0.825];    \n     L  = "
      "[+0.970; +0.970; -1.810; -1.810];\n     Kx = [+45000; +45000; +45000; +45000];      \n     Ky = [-50000; -50000;"
      " -50000; -50000];    \n     M  = 1521;                  \n     Iz = 1816;          \n     R_whl = 0.329;\n% Calc"
      "ulate Tyre Kinematic\n    vx_whl = zeros(4,1);\n    vy_whl = zeros(4,1);\n     v_whl = zeros(4,1);\n\n    kappa_"
      "whl = zeros(4,1);\n    alpha_whl = zeros(4,1);\n\n    for i = 1:1:4\n        vx_whl(i,1) = vx_veh - W(i,1)*avz_v"
      "eh;\n        vy_whl(i,1) = vy_veh + L(i,1)*avz_veh;\n         v_whl(i,1) = cos(delta_whl(i,1))*sqrt(vx_whl(i,1)^"
      "2 + vy_whl(i,1)^2);\n\n        kappa_whl(i,1) = (avy_whl(i,1)*R_whl - v_whl(i,1))/v_whl(i,1); \n        alpha_wh"
      "l(i,1) = atan(vy_whl(i,1)/vx_whl(i,1)) - delta_whl(i,1);\n    end\n\n% Calculate State   \n     ax_veh =  vy_veh"
      "*avz_veh;\n     ay_veh = -vx_veh*avz_veh;\n    aaz_veh = 0;\n    for j = 1:1:4\n        ax_veh = ax_veh + ...\n "
      "           (1/M)*(Kx(i,1)*kappa_whl(i,1)*cos(delta_whl(i,1)) - ...\n                   Ky(i,1)*alpha_whl(i,1)*si"
      "n(delta_whl(i,1)));\n        ay_veh = ay_veh + ...\n            (1/M)*(Kx(i,1)*kappa_whl(i,1)*sin(delta_whl(i,1)"
      ") + ...\n                   Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));\n        aaz_veh = aaz_veh + ...\n     "
      "       (1/Iz)*(-W(i,1))*...\n            (Kx(i,1)*kappa_whl(i,1)*cos(delta_whl(i,1)) - ...\n             Ky(i,1)"
      "*alpha_whl(i,1)*sin(delta_whl(i,1))) + ...\n            (1/Iz)*(L(i,1))*...\n            (Kx(i,1)*kappa_whl(i,1)"
      "*sin(delta_whl(i,1)) - ...\n             Ky(i,1)*alpha_whl(i,1)*cos(delta_whl(i,1)));\n    end\nend"
    }
  }
