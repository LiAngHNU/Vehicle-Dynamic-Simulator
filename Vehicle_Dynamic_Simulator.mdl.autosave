  state {
    id			    62
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    61
    treeNode		    [61 0 0 0]
    superState		    SUBCHART
    subviewer		    61
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function [kappa_whl, alpha_whl] = ...\n    Compute_Tyre_Kinematics(delta_whl, vx_veh, vy_veh, avz"
      "_veh, avy_whl)\n% Vehicle Parameters\n     W  = [+0.802; -0.802; +0.802; -0.802];    \n     L  = [+1.265; +1.265"
      "; -1.895; -1.895];         \n     R_whl = 0.368;\n% Calculate Tyre Kinematic\n    vx_whl = zeros(4,1);\n    vy_w"
      "hl = zeros(4,1);\n     v_whl = zeros(4,1);\n\n    kappa_whl = zeros(4,1);\n    alpha_whl = zeros(4,1);\n\n    fo"
      "r i = 1:1:4\n        vx_whl(i,1) = vx_veh - W(i,1)*avz_veh;\n        vy_whl(i,1) = vy_veh + L(i,1)*avz_veh;\n   "
      "      v_whl(i,1) = cos(delta_whl(i,1))*sqrt(vx_whl(i,1)^2 + vy_whl(i,1)^2);\n\n        kappa_whl(i,1) = (avy_whl"
      "(i,1)*R_whl - v_whl(i,1))/v_whl(i,1); \n        alpha_whl(i,1) = atan(vy_whl(i,1)/vx_whl(i,1)) - delta_whl(i,1);"
      "\n    end\nend"
    }
  }
