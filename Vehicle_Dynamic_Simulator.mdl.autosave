  state {
    id			    97
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    96
    treeNode		    [96 0 0 0]
    superState		    SUBCHART
    subviewer		    96
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function Fz_whl  = ...\n    Compute_Tyre_Dynamics(ax_veh, ay_veh)\n% Vehicle Parameters\n    M = "
      " 2020;\n    H  = 0.39;\n% Calculate Tyre Kinematic\n    Fz_whl = [5841; 5841; 4062; 4062];\n    coeffa = [-1; -1"
      "; +1; +1];\n    coeffb = [-1.895; 1.895; -1.265; +1.265];\n    for i = 1:1:4\n        Fz_whl(i,1) = Fz_whl(i,1) "
      "+ ax_veh*coeffa(i,1)*M*H/(2*3.16) + ...\n                                    ay_veh*coeffb(i,1)*M*H/(1.605*3.16)"
      ";\n    end\nend"
    }
  }
