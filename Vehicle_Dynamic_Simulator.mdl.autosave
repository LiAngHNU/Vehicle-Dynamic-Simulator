      Object {
	$PropName		"MaskObject"
	$ObjectID		114
	$ClassName		"Simulink.Mask"
	Initialization		"% Add Search Path\naddpath('Vehicles');\n\n% Test Vehicle Selector\nswitch VehicleFlag\n    case 1\n"
	"        Vehicle         = load('Truck_106_Daimler_Auman.mat').Vehicle;\n        TotalMass       = Vehicle.TotalMass;\n"
	"        TotalInertia    = Vehicle.TotalInertia;\n        TyreStiffness   = Vehicle.AxleStiffness;\n        AxlePositi"
	"on    = Vehicle.AxlePosition;\n%     case 2\n%     case 3\n%     case 4\n%         Vehicle         = load('Truck_106_"
	"Daimler_Auman.mat').Vehicle;\n%         TotalMass       = Vehicle.TotalMass;\n%         TotalInertia    = Vehicle.Tot"
	"alInertia;\n%         TyreStiffness   = Vehicle.AxleStiffness;\n%         AxlePosition    = Vehicle.AxlePosition;\n% "
	"        ...\nend"
	Display			"addpath('Pictures');\nimage('Vehicle.png'); "
	RunInitForIconRedraw	"off"
	Array {
	  Type			  "Simulink.MaskParameter"
	  Dimension		  2
	  Object {
	    $ObjectID		    115
	    Type		    "popup"
	    Array {
	      Type		      "Cell"
	      Dimension		      1
	      Cell		      "Truck_106_Daimler_Auman"
	      PropName		      "TypeOptions"
	    }
	    Name		    "VehicleFlag"
	    Prompt		    "Select Test Vehicle"
	    Value		    "Truck_106_Daimler_Auman"
	  }
	  Object {
	    $ObjectID		    116
	    Type		    "popup"
	    Array {
	      Type		      "Cell"
	      Dimension		      4
	      Cell		      "Static 2DOF Vehicle Model"
	      Cell		      "Static 2DOF Error Model"
	      Cell		      "Dynamic 2DOF Vehicle Model"
	      Cell		      "Dynamic 2DOF Error Model"
	      PropName		      "TypeOptions"
	    }
	    Name		    "ModelFlag"
	    Prompt		    "Model Type"
	    Value		    "Static 2DOF Vehicle Model"
	  }
	  PropName		  "Parameters"
	}
	Array {
	  Type			  "Simulink.dialog.Group"
	  Dimension		  2
	  Object {
	    $ObjectID		    117
	    Prompt		    "%<MaskType>"
